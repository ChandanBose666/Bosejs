{
  "name": "bose",
  "version": "0.0.1",
  "description": "The Hyper-Framework: Resumable Islands",
  "private": true,
  "workspaces": [
    "packages/*",
    "playground"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/prerender.mjs",
    "start": "node server.js",
    "serve": "npx serve playground",
    "publish:compiler": "npm publish --access public --workspace packages/compiler",
    "publish:runtime": "npm publish --access public --workspace packages/runtime",
    "publish:state": "npm publish --access public --workspace packages/state",
    "publish:core": "npm publish --access public --workspace packages/core",
    "publish:create-bose": "npm publish --access public --workspace packages/create-bose",
    "publish:all": "npm run publish:compiler && npm run publish:runtime && npm run publish:state && npm run publish:core && npm run publish:create-bose"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/plugin-syntax-jsx": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "marked": "^17.0.1"
  }
}
