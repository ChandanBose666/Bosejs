{
  "name": "@bosejs/compiler",
  "version": "0.2.0",
  "description": "The 'Brain' of Bose framework. Handles closure extraction and resumability shredding.",
  "type": "module",
  "main": "optimizer.js",
  "types": "optimizer.d.ts",
  "exports": {
    ".": {
      "types": "./optimizer.d.ts",
      "default": "./optimizer.js"
    },
    "./errors": {
      "types": "./errors.d.ts",
      "default": "./errors.js"
    }
  },
  "files": [
    "optimizer.js",
    "optimizer.d.ts",
    "errors.js",
    "errors.d.ts",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChandanBose666/Bosejs.git",
    "directory": "packages/compiler"
  },
  "dependencies": {
    "@babel/generator": "^7.0.0",
    "@babel/types": "^7.0.0"
  },
  "peerDependencies": {
    "@babel/core": "^7.0.0"
  },
  "keywords": [
    "bose",
    "compiler",
    "resumability",
    "qwik",
    "astro"
  ],
  "license": "MIT"
}
